# Base de datos (Railway provee esta URL automáticamente al vincular el servicio)
DATABASE_URL=postgresql://user:password@localhost:5432/campuslink

# JWT — cambiar por una clave larga y aleatoria en producción
JWT_SECRET=change_this_secret_in_production

# Puerto — Railway sobreescribe este valor automáticamente
PORT=3000

# Entorno — usar "development" para que TypeORM cree las tablas automáticamente
NODE_ENV=development

# URL del frontend — necesaria para CORS (pegar la URL de Vercel en producción)
FRONTEND_URL=http://localhost:5173
