{
  "name": "campuslink",
  "version": "1.0.0",
  "description": "CampusLink — Red de Oportunidades Universitarias",
  "private": true,
  "workspaces": [
    "apps/frontend",
    "apps/backend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=apps/frontend",
    "dev:backend": "npm run start:dev --workspace=apps/backend",
    "test:e2e": "npm run test:e2e --workspace=apps/frontend",
    "build:frontend": "npm run build --workspace=apps/frontend",
    "build:backend": "npm run build --workspace=apps/backend"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
